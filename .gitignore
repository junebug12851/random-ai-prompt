node_modules/
user-settings.js
user-settings.json
/output/**
!**/.gitkeep
results.json
*.lnk
*-private*
*private-*

# Local build/CI helper scripts & logs at the repo root (machine-specific, regenerated,
# never meant to be tracked). Underscore-prefixed by convention; transient logs go in tmp/.
/_*.bat
/_*.log
/_*.sh

# Generated documentation. jsdoc.config.json + scripts/build-docs.mjs ARE tracked;
# the generated site is not. JSDoc (docdash) builds the unified doc-site (code API +
# the notes wired in as tutorials) into docs/jsdoc/; build-docs.mjs stages the note
# tutorial pages under tmp/jsdoc-tutorials/ (tmp/ is already ignored). The whole
# /docs/ tree is generated output (the retired Doxygen build used /docs/html/).
/docs/
# list-cleanup audit artifacts (generated)
scripts/list-cleanup/out/

# Test artifacts (coverage, Playwright report/results). Vitest/Playwright CONFIGS,
# the tests/ suite, and the committed visual baselines (tests/e2e/*-snapshots/)
# ARE tracked; only the generated reports below are not.
/coverage/
gui/coverage/
/playwright-report/
/test-results/
/.vitest/

# Local-file storage backend (dev only)
engine-v3/gui/.gui-storage.json
