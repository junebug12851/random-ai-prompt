{
  "name": "random-ai-prompt-web",
  "private": true,
  "version": "2.0.8",
  "type": "module",
  "description": "React + Vite SPA front-end for random-ai-prompt (online BYOK or local).",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:extract": "formatjs extract \"src/**/*.{js,jsx}\" --ignore \"**/*.test.*\" --out-file src/i18n/messages/en.json --id-interpolation-pattern \"[sha512:contenthash:base64:6]\"",
    "i18n:compile": "formatjs compile src/i18n/messages/en.json --out-file src/i18n/compiled/en.json",
    "i18n:pseudo": "formatjs compile src/i18n/messages/en.json --ast --pseudo-locale en-XA --out-file src/i18n/compiled/en-XA.json",
    "i18n": "npm run i18n:extract && npm run i18n:pseudo",
    "i18n:check": "npm run i18n:extract && git diff --exit-code src/i18n/messages/en.json",
    "lint:i18n": "eslint src"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "lodash": "^4.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.14"
  },
  "devDependencies": {
    "@fontsource/maven-pro": "^5.2.10",
    "@fontsource/space-grotesk": "^5.2.10",
    "@formatjs/cli": "^6.16.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-formatjs": "^11.3.14",
    "eslint": "^10.6.0",
    "eslint-plugin-formatjs": "^6.4.16",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@emnapi/runtime": "^1.11.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/wasi-threads": "^1.2.2"
  }
}
