{
  "plugins": ["plugins/markdown"],
  "recurseDepth": 10,
  "source": {
    "include": ["engine-v3/src", "engine-v3/data", "README.md", "engine-v3/tmp/webapp-docs"],
    "includePattern": ".+\\.js$",
    "excludePattern": "(node_modules|frontend[\\\\/]lib[\\\\/]|\\.min\\.js$)"
  },
  "opts": {
    "destination": "./docs/jsdoc/",
    "recurse": true,
    "readme": "./README.md",
    "encoding": "utf8",
    "template": "engine-v3/node_modules/docdash",
    "tutorials": "./engine-v3/tmp/jsdoc-tutorials"
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  },
  "docdash": {
    "search": true,
    "collapse": true,
    "wrap": true,
    "typedefs": true,
    "scripts": ["assets/docs-theme/fairyfox-docs.js"],
    "meta": {
      "title": "Random AI Prompt — docs · Fairy Fox",
      "description": "Code API and project notes for Random AI Prompt, a project under Fairy Fox (fairyfox.io).",
      "keyword": "random-ai-prompt, Fairy Fox, JSDoc, dynamic prompts"
    },
    "sectionOrder": [
      "Tutorials",
      "Modules",
      "Namespaces",
      "Classes",
      "Interfaces",
      "Events",
      "Mixins",
      "Externals",
      "Global"
    ],
    "menu": {
      "GitHub ↗": {
        "href": "https://github.com/junebug12851/random-ai-prompt",
        "target": "_blank",
        "class": "menu-item"
      }
    }
  }
}
