{
  "name": "@random-ai-prompt/mobile",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "catalog": "node ../../scripts/build-metro-catalog.mjs --tier=full",
    "catalog:play": "node ../../scripts/build-metro-catalog.mjs --tier=sfw",
    "prestart": "npm run catalog",
    "preexport:android": "npm run catalog",
    "start": "expo start",
    "android": "expo start --android",
    "web": "expo start --web",
    "export:android": "expo export --platform android",
    "test": "jest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@shopify/flash-list": "2.0.2",
    "compromise": "^14.15.1",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.23",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lodash": "^4.18.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@shopify/flash-list|expo-.*))"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js?(x)"
    ],
    "moduleNameMapper": {
      "^shared/(.*)$": "<rootDir>/../shared/$1",
      "^@babel/runtime/(.*)$": "<rootDir>/node_modules/@babel/runtime/$1"
    }
  }
}
