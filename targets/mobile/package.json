{
  "name": "@random-ai-prompt/mobile",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "link:engine": "node scripts/link-engine.mjs",
    "catalog": "node ../../scripts/build-metro-catalog.mjs --tier=full",
    "catalog:play": "node ../../scripts/build-metro-catalog.mjs --tier=sfw",
    "setup": "npm run link:engine && npm run catalog",
    "prestart": "npm run setup",
    "preexport:android": "npm run setup",
    "start": "expo start",
    "android": "expo start --android",
    "web": "expo start --web",
    "export:android": "expo export --platform android"
  },
  "dependencies": {
    "compromise": "^14.15.1",
    "expo": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "lodash": "^4.18.1",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "babel-preset-expo": "^57.0.2"
  }
}