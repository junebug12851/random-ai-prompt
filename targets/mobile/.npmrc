# Detox's Expo config plugin (@config-plugins/detox@11) still declares `expo@^53` as a peer while this
# app is on Expo 54 -- a stale peer range, not a real incompatibility (the plugin only edits the
# GENERATED Android project: the androidTest source set, the instrumentation runner, the network
# security config). npm treats that as a hard ERESOLVE failure, so every `npm install` here -- yours,
# CI's, a new contributor's -- would otherwise need to remember `--legacy-peer-deps`.
#
# Declaring it once, in the package that needs it, is the difference between a rule and a rule people
# actually follow. Revisit when the plugin widens its peer range.
legacy-peer-deps=true