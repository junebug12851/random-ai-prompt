{
  "name": "random-ai-prompt",
  "version": "2.51.1",
  "description": "An open-source generator for AI image and text prompts that automatically builds richer, more detailed prompts than most people write by hand, then runs them through 40+ models. Isomorphic prompt engine (engine/) + React/Vite web app (targets/web/).",
  "type": "module",
  "main": "engine/core/engine.js",
  "author": "junebug12851",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "web": "npm --prefix targets/web run dev",
    "web:dev": "npm --prefix targets/web run dev",
    "web:build": "npm --prefix targets/web run build",
    "web:preview": "npm --prefix targets/web run preview",
    "start": "npm run web:build && node targets/web/backend/serve.js",
    "serve": "node targets/web/backend/serve.js",
    "web:install": "npm --prefix targets/web install",
    "cli": "node targets/cli/bin/prompt.js",
    "cli:install": "npm --prefix targets/cli install",
    "gen:accents": "node scripts/gen-accents.mjs",
    "postinstall": "npm --prefix targets/web install && npm --prefix targets/cli install",
    "lint": "eslint . && npm run lint:css",
    "lint:fix": "eslint . --fix && npm run lint:css:fix",
    "lint:css": "stylelint \"targets/web/**/*.css\"",
    "lint:css:fix": "stylelint \"targets/web/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "node scripts/smoke-test.mjs",
    "check:docs": "node scripts/check-links.mjs",
    "check:tidy": "node scripts/check-tidy.mjs",
    "manifest": "node scripts/build-data-manifest.mjs",
    "metro:catalog": "node scripts/build-metro-catalog.mjs",
    "metro:parity": "node scripts/build-metro-catalog.mjs --tier=full && node scripts/metro-parity-check.mjs",
    "mobile:parity": "node scripts/mobile-parity-check.mjs",
    "mobile:parity:engine": "npm run metro:parity",
    "mobile:parity:visual": "node scripts/mobile-visual-parity.mjs",
    "mobile:parity:all": "npm run mobile:parity:engine && npm run mobile:parity && npm run mobile:parity:visual",
    "docs": "node scripts/build-docs.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:web": "npm --prefix targets/web run test",
    "test:web:coverage": "npm --prefix targets/web run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:all": "node scripts/run-e2e-all.mjs",
    "test:perf": "npm run web:build && node scripts/check-bundle-size.mjs",
    "test:perf:scenarios": "playwright test --config playwright.perf.config.js",
    "profile": "node scripts/profile-scenarios.mjs",
    "screenshots": "node scripts/screenshots/capture.mjs --build",
    "test:lhci": "lhci autorun",
    "test": "npm run check:docs && npm run lint && npm run smoke && npm run mobile:parity && npm run test:unit && npm run test:web",
    "test:all": "npm run test && npm run test:e2e && npm run test:perf && npm run test:perf:scenarios"
  },
  "dependencies": {
    "compromise": "^14.15.1",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "docdash": "^2.0.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "gifenc": "^1.0.3",
    "globals": "^17.7.0",
    "jsdoc": "^4.0.5",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "vitest": "^4.1.9",
    "wordpos": "^2.1.0"
  },
  "overrides": {
    "@emnapi/runtime": "^1.11.1",
    "@emnapi/core": "^1.11.1",
    "@emnapi/wasi-threads": "^1.2.2",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
