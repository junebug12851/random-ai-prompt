{
  "name": "random-ai-prompt",
  "version": "2.2.0",
  "description": "Random AI prompt + image generator for Stable Diffusion WebUI, with a CLI and a local web UI.",
  "type": "module",
  "main": "src/index.js",
  "author": "junebug12851",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/index.js",
    "server": "node src/server.js",
    "webui": "node src/server.js",
    "web": "npm --prefix web-app run dev",
    "web:dev": "npm --prefix web-app run dev",
    "web:build": "npm --prefix web-app run build",
    "web:preview": "npm --prefix web-app run preview",
    "web:install": "npm --prefix web-app install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "node scripts/smoke-test.mjs",
    "docs": "node scripts/build-docs.mjs",
    "test": "npm run lint && npm run smoke"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "compromise": "^14.15.1",
    "crc": "^4.3.2",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "open": "^11.0.0",
    "pug": "^3.0.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "docdash": "^2.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "prettier": "^3.0.0",
    "wordpos": "^2.1.0"
  }
}
